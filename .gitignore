# =============================================================================
# SANAI — Root .gitignore
# Covers: Python/FastAPI backend, React/TypeScript/Vite frontend, editors, OS
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
build/
dist/
develop-eggs/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
wheels/
share/python-wheels/
sdist/
var/

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/

# uv
# uv.lock is intentionally committed — do NOT ignore it

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
cover/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# Other Python tools
.pdm.toml
.ropeproject
.spyderproject
.spyproject
.pybuilder/
target/
.ipynb_checkpoints
profile_default/
ipython_config.py

# Celery
celerybeat-schedule
celerybeat.pid

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
.bun-cache/
dist/
dist-ssr/
*.local

# Logs (npm/yarn/pnpm)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build caches
.cache/
.turbo/
.next/
.nuxt/
.output/
.parcel-cache/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*.sw?
*~
\#*\#
.\#*

# Sublime Text
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Misc / Project-specific
# -----------------------------------------------------------------------------
data/
ref/
refs/
img/
imgs/
*.tmp
*.bak

# Sphinx / MkDocs
docs/_build/
/site
