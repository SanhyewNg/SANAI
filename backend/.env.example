# Backend environment template for local development.
#
# Copy this file to .env and replace placeholder values before running the API.
# Keep real secrets out of git and use your hosting provider's secret manager in production.

# Environment label: local, staging, production, Render, etc.
ENV=Render

# Optional unless OpenAI-backed features are enabled.
OPENAI_API_KEY="REPLACE_WITH_OPENAI_API_KEY"
# Optional unless ElevenLabs text-to-speech is enabled.
ELEVEN_LABS_API_KEY="REPLACE_WITH_ELEVEN_LABS_API_KEY"

# Human-readable API name.
PROJECT_NAME="SANAI Backend API"
# Required: long random secret used to sign JWTs.
SECRET_KEY="REPLACE_WITH_LONG_RANDOM_SECRET"

# MongoDB connection settings.
DB_URL="mongodb+srv://USERNAME:PASSWORD@HOST/?retryWrites=true&w=majority&appName=APP_NAME"
DB_NAME="SanAI_on_Render"

# Initial seeded accounts created on startup. Replace emails and passwords.
MANAGERS=[{"email": "manager@example.com","pw":"REPLACE_WITH_BOOTSTRAP_PASSWORD", "avatar": "/assets/users/OceanStar.png", "first_name":"Manager", "last_name": "User"}]
DEVELOPERS=[{"email": "developer@example.com","pw":"REPLACE_WITH_BOOTSTRAP_PASSWORD", "avatar": "/assets/users/SanhyewNg.png", "first_name":"Developer", "last_name": "User"}]

# Optional unless Google sign-in is enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Backend base URL used to build the OAuth callback URL.
SSO_CALLBACK_HOSTNAME="http://localhost:8000"

# Token lifetime settings.
ACCESS_TOKEN_EXPIRES_IN_MINUTES=15
REFRESH_TOKEN_EXPIRES_IN_MINUTES=10080
JWT_ALGORITHM=HS256

# Frontend origin allowed by the backend. Local Vite default is http://localhost:5173.
CLIENT_ORIGIN="http://localhost:5173"

# SMTP configuration for verification/reset email flows.
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USERNAME=REPLACE_WITH_EMAIL_USERNAME
EMAIL_PASSWORD=REPLACE_WITH_EMAIL_PASSWORD
EMAIL_FROM=admin@admin.com

# Optional telemetry configuration.
LOGFIRE_TOKEN=REPLACE_WITH_LOGFIRE_TOKEN
LOGFIRE_PYDANTIC_PLUGIN_RECORD=all